; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Azard"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://buwcryw1eujb2"

[autoload]

Constants="*uid://c4e7ccrn2c5n7"
GameState="*uid://b62r1g1ijxyjc"
DragService="*uid://m2jbm3o7s6bf"
EventManager="*uid://dbw18b0bf5ody"
BookEventBus="*uid://b2hortd7cvbwd"

[display]

window/size/viewport_width=1980
window/size/viewport_height=1080
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/default_font_multichannel_signed_distance_field=true
theme/custom_font="uid://dk8qd4ll5xlvx"

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

common/physics_ticks_per_second=30
3d/physics_engine="Jolt Physics"
3d/solver/solver_iterations=8
common/physics_interpolation=true

[rendering]

occlusion_culling/bvh_build_quality=0
textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
textures/default_filters/anisotropic_filtering_level=0
environment/ssao/quality=0
environment/ssil/quality=0
occlusion_culling/occlusion_rays_per_thread=256
environment/glow/upscale_mode=0
environment/subsurface_scattering/subsurface_scattering_quality=0
global_illumination/sdfgi/frames_to_converge=0
occlusion_culling/use_occlusion_culling=true
